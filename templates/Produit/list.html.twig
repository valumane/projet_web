{% extends 'Layouts/layout_vente.html.twig' %}

{% block title %}{{ parent() }} : produits{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/produit.css') }}">
{% endblock %}

{% block titre_principal %}{{ parent() }} : liste des produits{% endblock %}

{% block vue %}
    <section class="page-produit-list">
        <h2>Produits disponibles</h2>

        <table>
            <thead>
            <tr>
                <th>Libellé</th>
                <th>Prix unitaire</th>
                <th>Stock</th>
                <th>Dans le panier</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
            {% for produit in produits %}
                {% set lignePanier = contenusPanier[produit.id] ?? null %}
                {% set quantitePanier = lignePanier ? lignePanier.quantite : 0 %}

                <tr>
                    <td>{{ produit.libelle }}</td>
                    <td>{{ produit.prixUnitaire }} €</td>
                    <td>{{ produit.quantiteStock }}</td>
                    <td>{{ quantitePanier }}</td>
                    <td>
                        {% if currentUser %}
                            {% if quantitePanier > 0 or produit.quantiteStock > 0 %}
                                <form method="post" action="{{ path('produit_panier_update', {id: produit.id}) }}">
                                    <select name="quantite">
                                        <option value="0" selected>0</option>
                                        {% for i in range(-quantitePanier, produit.quantiteStock) %}
                                            {% if i != 0 %}
                                                <option value="{{ i }}">
                                                    {% if i > 0 %}+{{ i }}{% else %}{{ i }}{% endif %}
                                                </option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <button type="submit">Modifier</button>
                                </form>
                            {% else %}
                                aucune action
                            {% endif %}
                        {% else %}
                            utilisateur absent
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Aucun produit disponible.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}