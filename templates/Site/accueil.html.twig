{% extends 'Layouts/layout_vente.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block titre_principal %}Accueil{% endblock %}

{% block vue %}
    <section>
        <h2>Bienvenue sur le site</h2>

        {% if currentUser %}
            <div class="carte">
                <p><strong>Utilisateur courant :</strong> {{ currentUser.login }}</p>
                <p><strong>Nom :</strong> {{ currentUser.nom }}</p>
                <p><strong>Prenom :</strong> {{ currentUser.prenom}}</p>
                <p><strong>Admin :</strong> {{ currentUser.isAdmin ? 'oui' : 'non' }}</p>
                <p><strong>Super-admin :</strong> {{ currentUser.isSuperAdmin ? 'oui' : 'non' }}</p>
                <p><strong>Pays :</strong>
                    {% if currentUser.pays %}
                        {{ currentUser.pays.nom }}
                    {% else %}
                        aucun
                    {% endif %}
                </p>
            </div>
        {% else %}
            <p>Aucun utilisateur courant.</p>
        {% endif %}
    </section>
{% endblock %}