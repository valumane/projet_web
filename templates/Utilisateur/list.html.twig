{% extends 'Layouts/layout_vente.html.twig' %}

{% block title %}{{ parent() }} : utilisateurs{% endblock %}

{% block titre_principal %}{{ parent() }} : gestion des utilisateurs{% endblock %}

{% block vue %}
    <section>
        <h2>Liste des utilisateurs</h2>

        <table>
            <thead>
            <tr>
                <th>Login</th>
                <th>Mot de passe hashé</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Date de naissance</th>
                <th>Statut</th>
                <th>Pays</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.login }}</td>
                    <td>{{ user.password }}</td>
                    <td>{{ user.nom }}</td>
                    <td>{{ user.prenom }}</td>
                    <td>{{ user.dateNaissance ? user.dateNaissance|date('Y-m-d') : '' }}</td>
                    <td>
                        {% if user.isSuperAdmin %}
                            super-admin
                        {% elseif user.isAdmin %}
                            admin
                        {% else %}
                            client
                        {% endif %}
                    </td>
                    <td>
                        {% if user.pays %}
                            {{ user.pays.nom }}
                        {% else %}
                            aucun
                        {% endif %}
                    </td>
                    <td>
                        {% if user.isSuperAdmin or user.id == currentUser.id %}
                            suppression interdite
                        {% else %}
                            <a href="{{ path('utilisateur_delete', {id: user.id}) }}">Supprimer</a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">Aucun utilisateur affiché.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}