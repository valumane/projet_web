{# entête du site #}

<div class="bandeau-superieur">
    <p class="bandeau-gauche">Bienvenue sur le site de vente</p>

    <p class="bandeau-droite">
        {% if currentUser is null %}
            Non connecté
        {% elseif currentUser.isSuperAdmin %}
            Connecté : {{ currentUser.login }} (super-admin)
        {% elseif currentUser.isAdmin %}
            Connecté : {{ currentUser.login }} (admin)
        {% else %}
            Connecté : {{ currentUser.login }} (client)
        {% endif %}
    </p>
</div>