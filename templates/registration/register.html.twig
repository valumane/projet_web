{% extends 'Layouts/layout_vente.html.twig' %}

{% block title %}{{ parent() }} : inscription{% endblock %}

{% block titre_principal %}{{ parent() }} : inscription{% endblock %}

{% block vue %}
    <section class="page-register">
        <h2>Créer un compte</h2>

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.login) }}
            {{ form_row(registrationForm.nom) }}
            {{ form_row(registrationForm.prenom) }}
            {{ form_row(registrationForm.dateNaissance) }}
            {{ form_row(registrationForm.pays) }}
            {{ form_row(registrationForm.plainPassword) }}

            <button type="submit">Créer le compte</button>
        {{ form_end(registrationForm) }}
    </section>
{% endblock %}